{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "headers": {
        "Cache-Control": "public, max-age=3600, s-maxage=86400"
      }
    },
    {
      "src": "/_next/static/(.*)",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/static/(.*)",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    }
  ],
  "env": {
    "NEXT_PUBLIC_APP_URL": "https://daic.org",
    "NEXT_PUBLIC_GA_ID": "",
    "NEXT_PUBLIC_SENTRY_DSN": ""
  },
  "regions": ["hkg1"],
  "github": {
    "silent": true,
    "autoAlias": true
  },
  "public": false,
  "cleanUrls": true,
  "trailingSlash": false
}